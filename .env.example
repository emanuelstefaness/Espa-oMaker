# Supabase (obrigatório para rodar o app)
# Copie para .env.local e preencha com os valores do seu projeto.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# ── Resumo semanal por email (função serverless /api/resumo-semanal) ──
# Configure estas variáveis na Vercel (Settings → Environment Variables).
# NUNCA comitar valores reais — são segredos de servidor (sem prefixo VITE_).
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta
RESEND_API_KEY=sua-resend-api-key
EMAIL_FROM=onboarding@resend.dev
CHEFE_EMAIL=chefe@exemplo.com
# Senha aleatória que protege o disparo automático do cron (gere uma forte).
CRON_SECRET=troque-por-um-valor-aleatorio
